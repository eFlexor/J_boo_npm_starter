{
  "name": "j-boo-npm-starter",
  "version": "2.0.0",
  "private": true,
  "description": "SalesChatGPT - offline-first inventory management app for resellers, built with vanilla JS and IndexedDB.",
  "author": "eFlexor",
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/eFlexor/J_boo_npm_starter.git" },
  "bugs": { "url": "https://github.com/eFlexor/J_boo_npm_starter/issues" },
  "homepage": "https://github.com/eFlexor/J_boo_npm_starter#readme",
  "scripts": {
    "build": "npm run css",
    "css-compile": "sass --style=compressed --source-map --embed-sources scss:assets/css/",
    "css-lint": "stylelint scss/",
    "css-prefix": "postcss --replace assets/css/starter.css --use autoprefixer --map",
    "css-purge": "purgecss --keyframes --css assets/css/starter.css --content index.html --output assets/css/",
    "css": "npm-run-all css-compile css-prefix",
    "server": "serve --listen 3000",
    "start": "npm-run-all --parallel watch server",
    "watch": "nodemon -e html,scss -x \"npm run css\"",
    "test": "npm run css-lint && npm run css"
  },
  "keywords": ["inventory","reseller","pwa","indexeddb","offline","bootstrap","sass"],
  "dependencies": {
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "@popperjs/core": "^2.11.8"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "nodemon": "^3.1.0",
    "npm-run-all2": "^6.2.0",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.0",
    "purgecss": "^6.0.0",
    "sass": "^1.77.0",
    "serve": "^14.2.3",
    "stylelint": "^16.6.1",
    "stylelint-config-twbs-bootstrap": "^14.0.0"
  }
}
